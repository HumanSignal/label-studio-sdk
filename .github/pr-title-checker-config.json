{
  "LABEL": {
    "name": "title needs formatting",
    "color": "EEEEEE"
  },
  "CHECKS": {
    "prefixes": [
      "build: ",
      "fix: ",
      "feat: ",
      "docs: ",
      "chore: ",
      "chore(deps): ",
      "chore(deps-dev): ",
      "build(deps): ",
      "build(deps-dev): ",
      "ci: ",
      "perf: ",
      "refactor: ",
      "revert: ",
      "style: ",
      "test: "
    ],
    "ignoreLabels": [
      "skip-changelog",
      "skip-ci"
    ],
    "regexp": ".*:\\s[A-Z0-9]+-[0-9]+:\\s.*",
    "regexpFlags": "i"
  },
  "MESSAGES": {
    "success": "PR title is valid",
    "failure": "PR title is invalid",
    "notice": "For more information, see [Conventional Commits specification](https://conventionalcommits.org)"
  }
}